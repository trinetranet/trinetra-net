{
  "manifest_version": 3,
  "name": "Trinetra.net",
  "version": "7.1.0",
  "description": "AI reads Terms & Conditions for you. Flags dangerous clauses, cites Indian law, saves tamper-proof evidence to your PC.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "https://trinetra-net-production.up.railway.app/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Trinetra.net \u2014 Legal Intelligence"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
